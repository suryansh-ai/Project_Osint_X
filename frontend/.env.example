# Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
VITE_API_BASE_URL=http://localhost:5000/api
VITE_WS_URL=ws://localhost:5000/ws

# Analytics
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_ENDPOINT=/api/analytics/events

# Google Analytics 4
VITE_GA_ENABLED=false
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Cloudflare Integration
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY=
VITE_CLOUDFLARE_ANALYTICS_TOKEN=

# CAPTCHA Configuration
# Provider options: 'turnstile', 'recaptcha-v2', 'recaptcha-v3'
VITE_CAPTCHA_PROVIDER=turnstile
VITE_RECAPTCHA_SITE_KEY=
VITE_RECAPTCHA_V3_SITE_KEY=

# Feature Flags
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_PWA=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_MOCK_MODE=false
VITE_ENABLE_TELEMETRY=true

# Performance
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_BUNDLE_SIZE_LIMIT=500kb

# Rate Limiting
VITE_RATE_LIMIT_ENABLED=true
VITE_RATE_LIMIT_MAX_REQUESTS=100
VITE_RATE_LIMIT_WINDOW=3600000

# External Services (Optional)
VITE_GOOGLE_MAPS_API_KEY=

# Firebase Phone Authentication
# Get these from Firebase Console: https://console.firebase.google.com
# 1. Create/select project > Project Settings > Your apps > Add Web app
# 2. Enable Phone Auth: Authentication > Sign-in method > Phone
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Metadata
VITE_APP_NAME=OsintX
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=development
